{
  "name": "@smilodon/solid",
  "version": "1.5.0",
  "description": "SolidJS adapter for @smilodon/core",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "COMPLETE-GUIDE.md"
  ],
  "scripts": {
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist/types"
  },
  "peerDependencies": {
    "@smilodon/core": "^1.5.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.9",
    "typescript": "^5.6.2",
    "vite": "^5.4.21",
    "vite-plugin-solid": "^2.11.8"
  }
}