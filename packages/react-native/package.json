{
  "name": "@smilodon/react-native",
  "version": "1.9.0-debug.0",
  "description": "React Native adapter for Smilodon",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "react-native": "./dist/index.native.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/index.native.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "COMPLETE-GUIDE.md"
  ],
  "scripts": {
    "build": "node scripts/embed-core.mjs && tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-native": ">=0.74.0",
    "react-native-webview": ">=13.12.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-native": "^0.76.9",
    "react-native-webview": "^13.12.5",
    "typescript": "^5.6.2"
  }
}